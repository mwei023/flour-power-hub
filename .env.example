# ============================================
# Frontend Environment Variables
# Copy this to .env and fill in your values
# ============================================

# API Base URL - Point this to your deployed backend
# For local development: http://localhost:3001/api/v1
# For production: https://your-backend.railway.app/api/v1
VITE_API_BASE_URL=/api/v1

# Alternative API URL (full URL, useful for production)
VITE_API_URL=https://your-backend-production.up.railway.app/api/v1

# App Configuration
VITE_APP_NAME=Flour Power Hub
VITE_APP_VERSION=1.0.0

