# Posho Mill Tracker - Environment Configuration
# Copy this file to .env and fill in your values

# ==================== SERVER ====================
NODE_ENV=development
PORT=3001
API_PREFIX=/api
API_VERSION=v1

# ==================== DATABASE ====================
# PostgreSQL Connection (from your test credentials)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=poshomill
DB_USER=mwei
DB_PASSWORD=23042003mwei
DB_SSL=false

# ==================== JWT AUTH ====================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ==================== RATE LIMITING ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://amani.mwei.co.ke

# ==================== M-PESA DARAYA API CONFIGURATION ====================
# Get these credentials from: https://developer.safaricom.co.ke/

# Use sandbox for testing, api.safaricom.co.ke for production
MPESA_ENV=sandbox

# Test Credentials (provided by user)
MPESA_CONSUMER_KEY=your-consumer-key-from-daraja
MPESA_CONSUMER_SECRET=your-consumer-secret-from-daraja
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=Safaricom123!!
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Business Paybill Number (your actual business shortcode)
MPESA_BUSINESS_SHORTCODE=600997

# Party A (Shortcode for B2C)
MPESA_PARTY_A=600997

# Party B (Phone number for B2C)
MPESA_PARTY_B=254708374149

# Webhook URL (must be HTTPS in production)
# For local testing, use ngrok or similar: https://your-ngrok-url/api/payments/webhook
MPESA_CALLBACK_URL=https://amani.mwei.co.ke/api/payments/webhook

# ==================== FRONTEND URL ====================
VITE_API_BASE_URL=https://amani.mwei.co.ke/api/v1

