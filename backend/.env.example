# ============================================
# Flour Power Hub - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# ============ SERVER CONFIG ============
NODE_ENV=production
PORT=3001

# ============ DATABASE (Neon PostgreSQL) ============
# Get these from https://neon.tech after creating your project
DB_CLIENT=pg
DB_HOST=ep-xxx.us-east-1.aws.neon.tech
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=flour_power_hub
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/flour_power_hub?sslmode=require

# ============ JWT AUTHENTICATION ============
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secure-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d

# ============ CORS (Cross-Origin Resource Sharing) ============
# Add your Vercel frontend URL here (comma-separated)
CORS_ORIGIN=https://your-project.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=https://your-project.vercel.app,http://localhost:5173

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============ API CONFIG ============
API_PREFIX=/api
API_VERSION=v1

# ============ MPESA (Optional - For Kenya Payments) ============
# Only configure if using M-Pesa integration
# MPESA_ENV=sandbox  # Use 'production' for live
# MPESA_CONSUMER_KEY=your_consumer_key
# MPESA_CONSUMER_SECRET=your_consumer_secret
# MPESA_SHORTCODE=your_shortcode
# MPESA_PASSKEY=your_passkey

# ============ LOGGING ============
LOG_LEVEL=info

